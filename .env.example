# ── LLM Providers ─────────────────────────────────────────────────────────────

# Groq (primary LLM provider — required)
# Get your key at https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# OpenAI (optional — stub only, not yet implemented)
OPENAI_API_KEY=your_openai_api_key_here

# Anthropic (optional — stub only, not yet implemented)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Google (optional — stub only, not yet implemented)
GOOGLE_API_KEY=your_google_api_key_here

# Ollama (optional — for local LLM inference)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_API_KEY=your_ollama_api_key_here

# ── Data Sources ───────────────────────────────────────────────────────────────

# Zotero (required for LibrarianAgent — bibliography search)
# Get your key at https://www.zotero.org/settings/keys
ZOTERO_API_KEY=your_zotero_api_key_here
ZOTERO_LIBRARY_ID=your_zotero_library_id_here

# Tavily (required for ResearcherAgent — web search)
# Get your key at https://tavily.com
TAVILEY_API_KEY=your_tavily_api_key_here

# ── Observability ──────────────────────────────────────────────────────────────

# Langfuse (optional — tracing and monitoring)
# Get your keys at https://cloud.langfuse.com
LANGFUSE_SECRET_KEY=your_langfuse_secret_key_here
LANGFUSE_PUBLIC_KEY=your_langfuse_public_key_here
LANGFUSE_BASE_URL=https://cloud.langfuse.com
